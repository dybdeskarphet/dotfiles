polybar_toggle(){
	if [ ! -f "/tmp/polybar_toggle.dat" ] ; then
		polybar_toggle=1
		echo "${polybar_toggle}" > /tmp/polybar_toggle.dat
	else
		polybar_toggle=`cat /tmp/polybar_toggle.dat`
	fi

	if [[ $polybar_toggle -eq 1 ]]
	then
		polybar-msg cmd hide
		bspc config bottom_padding 0
		polybar_toggle=0
	else
		polybar-msg cmd show
		bspc config bottom_padding 22
		polybar_toggle=1
	fi

	echo "${polybar_toggle}" > /tmp/polybar_toggle.dat

}

powersave(){
	if killall picom
	then
		printf '%b\n' "\e[1;31m[*] \e[0mKilled picom."
	fi

	if killall polybar
	then
		printf '%b\n' "\e[1;31m[*] \e[0mKilled polybar."
	fi

	if bspc config bottom_padding 0
	then
		printf '%b\n' "\e[1;31m[*] \e[0mChanged the bspwm padding."
	fi

	if xbacklight -set 40
	then
		printf '%b\n' "\e[1;33m[-] \e[0mDecreased the brightness."
	fi	
}

solid_wallpaper() {

	if [[ "$input_2" = "pc" && "$input_3" != "" ]]; then
	convert -size 1920x1080 \
		canvas:"$input_3" \
		./wallpaper.png
	elif [[ "$input_2" = "phone" && "$input_3" != "" ]]; then
	convert -size 720x1560 \
		canvas:"$input_3" \
		./wallpaper.png
	else 
		printf '%b\n' "\e[31m! \e[0myou missed some arguments."
		printf '%b\n' "\e[1musage:\e[0m bundle -W pc #colorcode"
	fi


}

print_usage(){
	printf '\n%b\n' "  \e[1mBUNDLE OF OFTUSED TOOLS\e[0m"

	printf '\n%b\n' "\e[1mINFO COMMANDS\e[0m"
	printf '%b\n' "  bundle {-C --colors2}                     show colors in different backgrounds"
	printf '%b\n' "  bundle {-c --colors}                      show colors"
	printf '%b\n' "  bundle {-h --help}                        print this message"
	printf '%b\n' "  bundle {-w --weather} [city]              show the weather for the specified city"

	printf '\n%b\n' "\e[1mACTION COMMANDS\e[0m"
	printf '%b\n' "  bundle {-P --powersave}                   turn on the power saving mode"
	printf '%b\n' "  bundle {-b --polybar-toggle}              toggle polybar"

	printf '\n%b\n' "\e[1mIMAGE COMMANDS\e[0m"
	printf '%b\n' "  bundle {-W --solid--wallpaper} [pc/phone] make a single color wallpaper"
	printf '%b\n' "  bundle {-i --image-to-clipboard}          pipe an image to clipboard"
	printf '%b\n\n' "  bundle {-p --wrff}                        resize an image for 1560x720 screens"
	exit 1
}

case $1 in
	--colors | -c) colors ;;
	--colors2 | -C) colors_match ;;
	--image-to-clipboard | -i) image_to_clipboard ;;
	--polybar-toggle | -b) polybar_toggle ;;
	--powersave | -P) powersave ;;
	--solid-wallpaper | -W) solid_wallpaper ;;
	--weather | -w) weather ;;
	--wrff | -p) resize_for_phone ;;
	*) print_usage ;;
esac

