[Unit]
Description=Notify when the battery is low
Wants=notifyBattery.timer

[Service]
User=skarphet
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/skarphet/.Xauthority
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
ExecStart=/home/skarphet/code/sh/notify/notify-battery

[Install]
WantedBy=multi-user.target
