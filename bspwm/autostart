#!/bin/sh
# kill all already running autostart programs
killall picom > /dev/null
killall polybar > /dev/null
killall dunst > /dev/null
killall picom > /dev/null
killall urxvtd > /dev/null
killall libinput-gestures > /dev/null
killall conky > /dev/null

# start picom and log errors
picom --config $HOME/.config/picom/picom.conf --log-level ERROR --log-file $HOME/.config/picom/picom.log &

# set wallpaper
$HOME/.config/feh/.fehbg &

# start duns and log
dunst -conf $HOME/.config/dunst/config.ini -verbosity warn 2>&1 | tee $HOME/.config/dunst/dunst.log &

# start polybar
polybar --log=error --config=$HOME/.config/polybar/config.ini <your username> 2>&1 | tee $HOME/.config/polybar/polybar.log &

# start gestures daemon
# libinput-gestures -c $HOME/.config/libinput-gestures/libinput-gestures.conf 2>&1 | tee $HOME/.config/libinput-gestures/libinput-gestures.log &

# start conky
sleep 0.5 && conky 2>&1 | tee $HOME/.config/conky/conky.log &
